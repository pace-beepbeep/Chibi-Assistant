<Window x:Class="ChibiAssistant.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:gif="http://wpfanimatedgif.codeplex.com"
        Title="Chibi Assistant" Height="450" Width="800"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" MouseDown="Window_MouseDown">
    <Grid Background="Transparent">
        <Image x:Name="ChibiImage"
               gif:ImageBehavior.AnimatedSource="/Assets/evernight-march-7th.gif"
               Stretch="Uniform"
               Width="200" Height="200" HorizontalAlignment="Left">
            <Image.ContextMenu>
                <ContextMenu x:Name="MyContextMenu">
                </ContextMenu>
            </Image.ContextMenu>
        </Image>

        <Popup x:Name="ChatPopup" PlacementTarget="{Binding ElementName=ChibiImage}" Placement="Right" StaysOpen="True" AllowsTransparency="True">
            <Border Background="#1E1E1E" BorderBrush="#3F3F46" BorderThickness="1" CornerRadius="12" Width="300" Height="420" Padding="10" Margin="10,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- ── Header ── -->
                    <TextBlock Text="Ngobrol sama Chibi 💕" Foreground="White" FontWeight="Bold" Margin="0,0,0,10"/>
                    <Button Content="✕" HorizontalAlignment="Right" Background="Transparent" Foreground="DarkGray" BorderThickness="0" Click="CloseChat_Click" Cursor="Hand"/>

                    <!-- ── Chat History ── -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="ChatHistoryList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{Binding BackgroundColor}" CornerRadius="8" Padding="10" Margin="0,5" HorizontalAlignment="{Binding Alignment}">
                                        <TextBlock Text="{Binding Message}" TextWrapping="Wrap" Foreground="White"/>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- ── Input Area ── -->
                    <StackPanel Grid.Row="2" Margin="0,10,0,0">

                        <!-- Typing / Listening indicator -->
                        <TextBlock x:Name="TypingIndicator"
                                   Text="Chibi sedang mengetik..."
                                   Foreground="Gray" FontStyle="Italic"
                                   Visibility="Collapsed" Margin="0,0,0,5"/>

                        <!-- 🎙 Voice status bar (muncul saat mic aktif) -->
                        <Border x:Name="VoiceStatusBar"
                                Background="#2D2D30" CornerRadius="6"
                                Padding="8,4" Margin="0,0,0,5"
                                Visibility="Collapsed">
                            <StackPanel Orientation="Horizontal">
                                <!-- Animasi dot merah berkedip -->
                                <Ellipse x:Name="RecordingDot"
                                         Width="8" Height="8" Fill="#FF4444"
                                         VerticalAlignment="Center" Margin="0,0,6,0">
                                    <Ellipse.Triggers>
                                        <EventTrigger RoutedEvent="Ellipse.Loaded">
                                            <BeginStoryboard>
                                                <Storyboard RepeatBehavior="Forever">
                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                     From="1" To="0.1" Duration="0:0:0.6"
                                                                     AutoReverse="True"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </Ellipse.Triggers>
                                </Ellipse>
                                <TextBlock x:Name="VoiceStatusText"
                                           Text="Mendengarkan..."
                                           Foreground="#FF8888" FontSize="11"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <!-- Input row: TextBox + Mic + Kirim -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Text input -->
                            <TextBox x:Name="ChatInput"
                                     Grid.Column="0"
                                     Background="#2D2D30" Foreground="White"
                                     BorderThickness="0" Padding="8"
                                     KeyDown="ChatInput_KeyDown"/>

                            <!-- 🎙 Mic Button -->
                            <Button x:Name="MicBtn"
                                    Grid.Column="1"
                                    Content="🎙"
                                    FontSize="14"
                                    Width="34" Height="34"
                                    Margin="5,0,0,0"
                                    Background="#3A3A3D"
                                    Foreground="White"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    ToolTip="Klik untuk mulai/berhenti rekam suara"
                                    Click="MicBtn_Click">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bg"
                                                Background="{TemplateBinding Background}"
                                                CornerRadius="6">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bg" Property="Background" Value="#FF4444"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <!-- Kirim Button -->
                            <Button x:Name="SendBtn"
                                    Grid.Column="2"
                                    Content="Kirim"
                                    Margin="5,0,0,0" Padding="10,5"
                                    Background="#007ACC" Foreground="White"
                                    BorderThickness="0"
                                    Click="SendBtn_Click" Cursor="Hand"/>
                        </Grid>
                    </StackPanel>
                </Grid>
            </Border>
        </Popup>
    </Grid>
</Window>
