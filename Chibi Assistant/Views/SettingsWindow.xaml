<Window x:Class="Chibi_Assistant.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:gif="http://wpfanimatedgif.codeplex.com"
        Title="⚙ Pengaturan Chibi" Height="520" Width="400"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#1E1E1E">

    <Window.Resources>
        <!-- Rounded Button Style -->
        <Style x:Key="RoundedBtn" TargetType="Button">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="20,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ComboBox Style -->
        <Style x:Key="DarkCombo" TargetType="ComboBox">
            <Setter Property="Background" Value="#2D2D30"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="BorderBrush" Value="#3F3F46"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <!-- Slider Style -->
        <Style x:Key="DarkSlider" TargetType="Slider">
            <Setter Property="Minimum" Value="0"/>
            <Setter Property="Maximum" Value="100"/>
            <Setter Property="IsSnapToTickEnabled" Value="True"/>
            <Setter Property="TickFrequency" Value="5"/>
        </Style>
    </Window.Resources>

    <Border Margin="0" Padding="20" Background="#1E1E1E">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ── Header ── -->
            <TextBlock Grid.Row="0" Text="⚙ Pengaturan" Foreground="White" FontSize="20" FontWeight="Bold" Margin="0,0,0,10"/>

            <!-- ── Scrollable Content ── -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,0,0,10">
                <StackPanel>

                    <!-- ══════════════════════════════════════ -->
                    <!-- SECTION: Pilih Karakter               -->
                    <!-- ══════════════════════════════════════ -->
                    <TextBlock Text="🎭 Pilih Karakter" Foreground="#AAAAAA" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8"/>

                    <Border Background="#2D2D30" CornerRadius="10" Padding="15" Margin="0,0,0,15">
                        <StackPanel>
                            <ComboBox x:Name="CharacterCombo"
                                      Style="{StaticResource DarkCombo}"
                                      DisplayMemberPath="DisplayName"
                                      SelectionChanged="CharacterCombo_SelectionChanged"/>

                            <!-- Preview area -->
                            <Border Background="#252526" CornerRadius="8" Margin="0,12,0,0"
                                    Padding="10" HorizontalAlignment="Center">
                                <StackPanel HorizontalAlignment="Center">
                                    <Image x:Name="PreviewImage"
                                           Width="120" Height="120"
                                           Stretch="Uniform" Margin="0,0,0,8"/>
                                    <TextBlock x:Name="PreviewGreeting"
                                               Foreground="#CCCCCC" FontSize="11"
                                               TextWrapping="Wrap" TextAlignment="Center"
                                               MaxWidth="250"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- ══════════════════════════════════════ -->
                    <!-- SECTION: Suara (TTS)                  -->
                    <!-- ══════════════════════════════════════ -->
                    <TextBlock Text="🔊 Suara (Text-to-Speech)" Foreground="#AAAAAA" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8"/>

                    <Border Background="#2D2D30" CornerRadius="10" Padding="15" Margin="0,0,0,10">
                        <StackPanel>
                            <!-- TTS Toggle -->
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Aktifkan Suara" Foreground="White" FontSize="13" VerticalAlignment="Center"/>
                                <CheckBox x:Name="TtsToggle" Grid.Column="1" VerticalAlignment="Center"
                                          Checked="TtsToggle_Changed" Unchecked="TtsToggle_Changed"/>
                            </Grid>

                            <!-- Volume Slider -->
                            <TextBlock Text="Volume" Foreground="#AAAAAA" FontSize="11" Margin="0,0,0,5"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="40"/>
                                </Grid.ColumnDefinitions>
                                <Slider x:Name="VolumeSlider" Style="{StaticResource DarkSlider}"
                                        ValueChanged="VolumeSlider_ValueChanged"/>
                                <TextBlock x:Name="VolumeLabel" Grid.Column="1"
                                           Foreground="White" FontSize="12"
                                           VerticalAlignment="Center" HorizontalAlignment="Right"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <!-- ══════════════════════════════════════ -->
            <!-- BUTTONS: Simpan & Batal (fixed bottom) -->
            <!-- ══════════════════════════════════════ -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="1" Content="💾 Simpan"
                        Style="{StaticResource RoundedBtn}"
                        Background="#007ACC"
                        Click="SaveBtn_Click"/>

                <Button Grid.Column="3" Content="Batal"
                        Style="{StaticResource RoundedBtn}"
                        Background="#3A3A3D"
                        Click="CancelBtn_Click"/>
            </Grid>

        </Grid>
    </Border>
</Window>
